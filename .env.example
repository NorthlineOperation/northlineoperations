NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=cms-files
QUOTE_STORAGE_BUCKET=quote-files

# Public site origin — canonical URLs, sitemap, robots, OpenGraph, JSON-LD
NEXT_PUBLIC_SITE_URL=https://northlineoperation.com

# Secret that protects the cron keep-alive endpoint (/api/cron/keep-alive).
# Set this in Vercel; Vercel sends it automatically on scheduled cron runs.
CRON_SECRET=

# Google Business reviews (optional). Enable "Places API (New)" in Google Cloud
# and create an API key. The Place ID can be set here OR in the CMS admin
# (Quote & Footer tab > Integrations); the CMS value takes priority.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Email (SMTP) — used for job application + quote request notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# true for port 465 (SSL); false/blank for 587 (STARTTLS)
SMTP_SECURE=
# Default "From" address, e.g. "Northline <no-reply@yourdomain.com>"
SMTP_FROM=
# Admin recipient for both notifications (defaults to admin@northlineoperation.com)
ADMIN_EMAIL=
# Optional per-type overrides (fall back to ADMIN_EMAIL)
JOB_APPLICATION_EMAIL_TO=
QUOTE_REQUEST_EMAIL_TO=
CONTACT_EMAIL_TO=
